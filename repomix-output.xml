<file path="packages/server/src/scripts/migrate-keys.ts">
/**
 * Migration script: keys.json -> MongoDB
 * Usage: pnpm tsx packages/server/src/scripts/migrate-keys.ts
 * Requires MONGO_URI env var
 */
import { createHash } from "node:crypto";
import { readFileSync } from "node:fs";
import { connectDb, disconnectDb } from "../db/connection-manager.js";
import { ApiKey } from "../db/models/api-key-model.js";
import { User } from "../db/models/user-model.js";

const MONGO_URI = process.env.MONGO_URI as string;
if (!MONGO_URI) {
	console.error("MONGO_URI env var required");
	process.exit(1);
}

const keysFile = process.env.API_KEYS_FILE ?? "./keys.json";

async function migrate(): Promise<void> {
	await connectDb(MONGO_URI);

	let keys: string[];
	try {
		const data = JSON.parse(readFileSync(keysFile, "utf-8")) as {
			keys: string[];
		};
		keys = data.keys;
	} catch {
		console.error(`Failed to read ${keysFile}`);
		await disconnectDb();
		process.exit(1);
	}

	// Create a default migration user
	let user = await User.findOne({ email: "migration@tunelo.local" }).lean();
	if (!user) {
		const created = await User.create({
			email: "migration@tunelo.local",
			passwordHash: "$2b$12$placeholder.for.migration.only.suspended",
			role: "admin",
			status: "suspended",
			plan: "free",
		});
		user = created.toObject();
		console.log(`Created migration user: ${String(user._id)}`);
	}

	let migrated = 0;
	for (const key of keys) {
		const keyHash = createHash("sha256").update(key).digest("hex");
		const keyPrefix = `${key.slice(0, 8)}...`;
		const exists = await ApiKey.findOne({ keyHash }).lean();
		if (exists) {
			console.log(`Key ${keyPrefix} already exists, skipping`);
			continue;
		}
		await ApiKey.create({
			userId: user._id,
			keyHash,
			keyPrefix,
			label: `Migrated key ${migrated + 1}`,
			status: "active",
		});
		migrated++;
		console.log(`Migrated key ${keyPrefix}`);
	}

	console.log(`Migration complete: ${migrated}/${keys.length} keys migrated`);
	await disconnectDb();
}

migrate().catch((err) => {
	console.error("Migration failed:", err);
	process.exit(1);
});
</file>

<file path="packages/server/src/services/admin-service.ts">
import { TuneloError } from "../api/middleware/error-handler.js";
import { ApiKey } from "../db/models/api-key-model.js";
import { User } from "../db/models/user-model.js";
import { tunnelManager } from "../tunnel-manager.js";

export async function listUsers(page: number, limit: number) {
	const skip = (page - 1) * limit;
	const [users, total] = await Promise.all([
		User.find()
			.select("-passwordHash -totpSecret")
			.sort({ createdAt: -1 })
			.skip(skip)
			.limit(limit)
			.lean(),
		User.countDocuments(),
	]);

	return {
		users: users.map((u) => ({
			id: String(u._id),
			email: u.email,
			role: u.role,
			status: u.status,
			plan: u.plan,
			createdAt: u.createdAt,
		})),
		total,
		page,
		pages: Math.ceil(total / limit),
	};
}

export async function updateUserStatus(
	userId: string,
	status: "active" | "suspended",
) {
	const user = await User.findById(userId);
	if (!user) {
		throw new TuneloError("TUNELO_AUTH_001", "User not found", 404);
	}
	user.status = status;
	await user.save();
	return { id: String(user._id), status: user.status };
}

export async function listAllKeys(page: number, limit: number) {
	const skip = (page - 1) * limit;
	const [keys, total] = await Promise.all([
		ApiKey.find()
			.select("-keyHash")
			.populate("userId", "email")
			.sort({ createdAt: -1 })
			.skip(skip)
			.limit(limit)
			.lean(),
		ApiKey.countDocuments(),
	]);

	return {
		keys: keys.map((k) => ({
			id: String(k._id),
			keyPrefix: k.keyPrefix,
			label: k.label,
			status: k.status,
			userEmail: (k.userId as unknown as { email: string })?.email ?? "unknown",
			createdAt: k.createdAt,
		})),
		total,
		page,
		pages: Math.ceil(total / limit),
	};
}

export async function revokeAnyKey(keyId: string) {
	const apiKey = await ApiKey.findById(keyId);
	if (!apiKey) {
		throw new TuneloError("TUNELO_KEY_002", "API key not found", 404);
	}
	apiKey.status = "revoked";
	await apiKey.save();
	tunnelManager.disconnectByKeyHash(apiKey.keyHash);
	return { id: String(apiKey._id), status: "revoked" };
}

export function getActiveTunnels() {
	const connections = tunnelManager.getAllConnections();
	return connections.map((c) => ({
		subdomain: c.subdomain,
		userId: c.userId,
		keyId: c.keyId,
		connectedAt: c.connectedAt,
	}));
}

export async function getSystemStats() {
	const [userCount, keyCount] = await Promise.all([
		User.countDocuments(),
		ApiKey.countDocuments({ status: "active" }),
	]);
	const stats = tunnelManager.getStats();

	return {
		totalUsers: userCount,
		totalActiveKeys: keyCount,
		activeTunnels: stats.activeTunnels,
		subdomains: stats.subdomains,
	};
}
