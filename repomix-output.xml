<file path="packages/server/src/key-store/json-file-key-store.ts">
import { createHash } from "node:crypto";
import { readFileSync, unwatchFile, watchFile } from "node:fs";
import { createLogger } from "../logger.js";
import type { KeyInfo, KeyStore } from "./key-store-types.js";

const logger = createLogger("tunelo-json-key-store");

function hashKey(key: string): string {
	return createHash("sha256").update(key).digest("hex");
}

export class JsonFileKeyStore implements KeyStore {
	private keyHashes = new Set<string>();

	constructor(private readonly filePath: string) {}

	async validate(keyHash: string): Promise<KeyInfo | null> {
		// If no keys loaded, accept all (dev mode)
		if (this.keyHashes.size === 0) {
			return {
				userId: "dev-user",
				keyId: "dev-key",
				keyHash,
				maxTunnels: 10,
				plan: "dev",
				role: "admin",
			};
		}

		if (!this.keyHashes.has(keyHash)) return null;

		return {
			userId: "file-user",
			keyId: "file-key",
			keyHash,
			maxTunnels: 10,
			plan: "free",
			role: "user",
		};
	}

	async recordUsage(_keyHash: string): Promise<void> {
		// No-op for file-based store
	}

	async initialize(): Promise<void> {
		this.loadKeys();
		watchFile(this.filePath, { interval: 5000 }, () => {
			logger.info("API keys file changed, reloading");
			this.loadKeys();
		});
		logger.info("JsonFileKeyStore initialized");
	}

	async shutdown(): Promise<void> {
		unwatchFile(this.filePath);
		logger.info("JsonFileKeyStore shut down");
	}

	private loadKeys(): void {
		try {
			const data = JSON.parse(readFileSync(this.filePath, "utf-8")) as {
				keys: string[];
			};
			this.keyHashes = new Set(data.keys.map(hashKey));
			logger.info({ count: this.keyHashes.size }, "API keys loaded");
		} catch (err) {
			logger.warn(
				{ filePath: this.filePath, err },
				"Failed to load API keys — accepting all connections",
			);
			this.keyHashes = new Set();
		}
	}
}
</file>

