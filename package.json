{
	"name": "tunelo",
	"private": true,
	"type": "module",
	"workspaces": ["packages/*"],
	"scripts": {
		"dev:server": "pnpm --filter @tunelo/server dev",
		"dev:client": "pnpm --filter @tunelo/client dev",
		"build": "pnpm --filter @tunelo/shared build && pnpm --filter @tunelo/server build && pnpm --filter @tunelo/client build",
		"build:server": "tsx scripts/build-server.ts",
		"clean": "rm -rf packages/*/dist dist",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "vitest run tests/e2e/",
		"test:unit": "vitest run packages/",
		"lint": "biome check .",
		"lint:fix": "biome check --fix ."
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@types/ws": "^8.5.0",
		"esbuild": "^0.27.4",
		"nanoid": "^5.0.0",
		"tsx": "^4.7.0",
		"typescript": "^5.4.0",
		"vitest": "^1.6.0",
		"ws": "^8.16.0"
	},
	"engines": {
		"node": ">=20"
	},
	"packageManager": "pnpm@9.15.0",
	"dependencies": {
		"socket.io": "^4.8.3",
		"socket.io-client": "^4.8.3"
	}
}
